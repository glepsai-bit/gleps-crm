# ===========================================
# GLEPS CRM Backend - Environment Variables
# ===========================================

# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

# Database (PostgreSQL)
DATABASE_URL=postgresql://gleps:gleps_secret@localhost:5432/gleps_crm?schema=public

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Chatwoot Integration
# Webhook secret for validating incoming webhooks from Chatwoot
# Get this from your Chatwoot instance webhook configuration
CHATWOOT_WEBHOOK_SECRET=your-chatwoot-webhook-secret

# Google Calendar OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# Logging
LOG_LEVEL=debug
